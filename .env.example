# Copy to .env and fill in values.
GROQ_API_KEY=your_groq_api_key_here
# Optional: https://console.groq.com/docs/models (defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MAX_TOKENS=4096

# CLI UX: Thought/Action/Observation trace when running `python agent.py` (0 = final report only)
# CIS_AGENT_TRACE=1
# Sentence-transformers tqdm bars (embedding batches / reranker); default off
# CIS_ST_SHOW_PROGRESS=0
GOOGLE_APPLICATION_CREDENTIALS=./fldr-network-prj-ba77-6f3a42848ccb.json
# Optional override if it differs from project_id inside the JSON:
# GCP_PROJECT_ID=your-project-id
# Optional audit scope. Prefer this for organization/folder-wide scans.
# GCP_AUDIT_SCOPE=organizations/123456789
# GCP_AUDIT_SCOPE=folders/123456789
# GCP_AUDIT_SCOPE=projects/your-project-id
# Safety limit for project-level detail calls under an org/folder scope.
# GCP_AUDIT_PROJECT_LIMIT=50

# Langfuse tracing (optional)
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# CIS knowledge base (ingestion / retriever)
# If you run uvicorn from backend/, ../.chroma_cis points to the repo-level DB.
# The agent normalizes this path to avoid empty CIS retrieval from another cwd.
# CHROMA_CIS_PATH=../.chroma_cis
# CIS_EMBEDDING_PROVIDER=bge
# CIS_EMBED_MODEL=BAAI/bge-large-en-v1.5
# CIS_EMBED_DEVICE=cuda   # auto-falls back to cpu if PyTorch has no CUDA build
# CIS_RERANK_DEVICE=cuda  # same fallback as above
# CIS_ENABLE_RERANK=1
# CIS_RERANK_MODEL=BAAI/bge-reranker-base
# OpenAI embeddings (optional): CIS_EMBEDDING_PROVIDER=openai  (+ OPENAI_API_KEY)
